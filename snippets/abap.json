  "REDUCE constructor": {
    "prefix": "REDUCE",
    "body": [
      "${1:result} = REDUCE ${2:i}(",
      "  INIT ${3:sum} = ${4:0}",
      "  FOR ${5:row} IN ${6:lt_rows}",
      "  NEXT ${3:sum} = ${3:sum} + ${5:row}-${7:value}",
      ")."
    ],
    "description": "Reduce internal table rows to one value"
  },
  "FILTER constructor": {
    "prefix": "FILTER",
    "body": [
      "${1:result} = FILTER ${2:ty_table}(",
