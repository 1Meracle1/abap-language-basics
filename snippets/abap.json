  "VALUE constructor": {
    "prefix": "VALUE",
    "body": [
      "${1:result} = VALUE ${2:type}(",
      "  ${3:field} = ${4:value}",
      ")."
    ],
    "description": "Create a value with a constructor expression"
  },
  "VALUE table constructor": {
    "prefix": "VALUE",
    "body": [
      "${1:lt_rows} = VALUE ${2:ty_table}(",
      "  ( ${3:field} = ${4:value} )",
      ")."
    ],
    "description": "Create an internal table value"
  },
  "VALUE table comprehension": {
    "prefix": "VALUE",
    "body": [
      "${1:lt_result} = VALUE ${2:ty_table}(",
      "  FOR ${3:ls_row} IN ${4:lt_rows}",
      "  ( ${3:ls_row} )",
      ")."
    ],
    "description": "Construct an internal table from the rows of another table"
  },
  "VALUE filtered table comprehension": {
    "prefix": "VALUE",
    "body": [
      "${1:lt_result} = VALUE ${2:ty_table}(",
      "  FOR ${3:ls_row} IN ${4:lt_rows} WHERE ( ${5:id} = ${6:value} )",
      "  ( ${3:ls_row} )",
      ")."
    ],
    "description": "Construct an internal table from rows selected by a WHERE condition"
  },
