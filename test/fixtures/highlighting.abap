  CASE sy-subrc.
    WHEN 0.
    WHEN OTHERS.
  ENDCASE.
ENDFORM.

FUNCTION z_example.
  TRY.
      DO 2 TIMES.
      ENDDO.
    CATCH cx_root.
  ENDTRY.
ENDFUNCTION.

MODULE status_0100 OUTPUT.
  WHILE sy-index < 2.
  ENDWHILE.
ENDMODULE.

