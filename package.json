{
  "name": "abap-language-basics",
  "displayName": "ABAP Language Basics",
  "description": "Lightweight ABAP syntax highlighting, snippets, folding, and editor configuration.",
  "version": "0.0.3",
  "publisher": "1meracle1",
  "license": "MIT",
  "author": "ABAP LSP contributors",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/1Meracle1/abap-language-basics.git"
  },
  "bugs": {
    "url": "https://github.com/1Meracle1/abap-language-basics/issues"
  },
  "homepage": "https://github.com/1Meracle1/abap-language-basics#readme",
  "preview": true,
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "abap",
    "sap",
    "syntax",
    "snippets"
  ],
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "capabilities": {
    "virtualWorkspaces": {
      "supported": true
    },
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "scripts": {
    "compile": "tsc -p ./test/tsconfig.json",
    "test": "npm run compile && node ./out/runTest.js",
    "package": "mkdir -p dist && vsce package --out dist/abap-language-basics-${npm_package_version}.vsix",
    "verify:package": "npm run package && node ./scripts/verify-vsix.mjs dist/abap-language-basics-${npm_package_version}.vsix"
  },
  "devDependencies": {
    "@types/mocha": "10.0.10",
    "@types/node": "20.19.24",
    "@types/vscode": "1.105.0",
    "@vscode/test-electron": "2.5.2",
    "@vscode/vsce": "3.9.2",
    "glob": "13.0.2",
    "mocha": "10.8.2",
    "ovsx": "1.0.2",
    "typescript": "5.9.3"
  },
  "overrides": {
    "serialize-javascript": "7.0.5"
  },
  "contributes": {
    "languages": [
      {
        "id": "abap",
        "aliases": [
          "ABAP",
          "abap"
        ],
        "extensions": [
          ".abap"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "abap",
        "scopeName": "source.abap",
        "path": "./syntaxes/abap.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "abap",
        "path": "./snippets/abap.json"
      }
    ],
    "configurationDefaults": {
      "[abap]": {
        "editor.wordBasedSuggestions": "off"
      }
    }
  }
}
