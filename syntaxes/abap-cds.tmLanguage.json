{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "ABAP CDS",
  "scopeName": "source.abap.cds",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#declarations" },
    { "include": "#annotations" },
    { "include": "#special-variables" },
    { "include": "#enum-values" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#keywords" },
    { "include": "#functions" },
    { "include": "#qualified-names" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.cds",
          "match": "//.*$"
        },
        {
          "name": "comment.block.cds",
          "begin": "/\\*",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.begin.cds" }
          },
          "end": "\\*/",
          "endCaptures": {
            "0": { "name": "punctuation.definition.comment.end.cds" }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.single.cds",
          "begin": "'",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.cds" }
          },
          "end": "'(?!')",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.cds" }
          },
          "patterns": [
            { "name": "constant.character.escape.cds", "match": "''" }
          ]
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "match": "(@)([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)",
          "captures": {
            "1": { "name": "punctuation.definition.annotation.cds" },
            "2": { "name": "entity.other.attribute-name.annotation.cds" }
          }
        },
        {
          "match": "([A-Za-z_][A-Za-z0-9_]*)(\\s*)(:)(?=\\s*(?:[#{\\[A-Za-z0-9'_-]|true\\b|false\\b))",
          "captures": {
            "1": { "name": "entity.other.attribute-name.property.cds" },
            "3": { "name": "punctuation.separator.key-value.cds" }
          }
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "match": "\\b(p_[A-Za-z0-9_]+)(\\s*)(:)",
          "captures": {
            "1": { "name": "variable.parameter.cds" },
            "3": { "name": "punctuation.separator.type.cds" }
          }
        },
        {
          "match": "(?i)\\b(define)(\\s+)(view)(\\s+)(entity)(\\s+)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.define.cds" },
            "3": { "name": "storage.type.view.cds" },
            "5": { "name": "storage.modifier.entity.cds" },
            "7": { "name": "entity.name.type.view.cds" }
          }
        },
        {
          "match": "(?i)\\b(from|join)(\\s+)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.source.cds" },
            "3": { "name": "entity.name.type.datasource.cds" }
          }
        },
        {
          "match": "(?i)\\b(association)(\\s+)(of)(\\s+)(one|many)(\\s+)(to)(\\s+)(one|many)(\\s+)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.association.cds" },
            "3": { "name": "keyword.other.cardinality.cds" },
            "5": { "name": "constant.language.cardinality.cds" },
            "7": { "name": "keyword.other.cardinality.cds" },
            "9": { "name": "constant.language.cardinality.cds" },
            "11": { "name": "entity.name.type.datasource.cds" }
          }
        },
        {
          "match": "(?i)\\b(as)(\\s+)(_[A-Za-z0-9_]+|[A-Za-z_][A-Za-z0-9_]*)(?=\\s*(?:[,;{]|$|\\n))",
          "captures": {
            "1": { "name": "keyword.other.alias.cds" },
            "3": { "name": "entity.name.alias.cds" }
          }
        }
      ]
    },
    "special-variables": {
      "patterns": [
        {
          "match": "(?i)(\\$)(parameters|projection|session)(?=\\b)",
          "captures": {
            "1": { "name": "punctuation.definition.variable.cds" },
            "2": { "name": "variable.language.cds" }
          }
        }
      ]
    },
    "enum-values": {
      "patterns": [
        {
          "name": "constant.language.enum.cds",
          "match": "#[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.builtin.cds",
          "match": "(?i)\\babap\\.(?:char|clnt|cuky|curr|dats|datn|dec|decfloat16|decfloat34|fltp|int1|int2|int4|int8|lang|numc|quan|raw|rawstring|sstring|string|tims|timn|unit|utclong)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.cds",
          "match": "(?i)\\b(?:true|false|null)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.other.ddl.cds",
          "match": "(?i)\\b(?:define|view|entity|with|parameters|as|select|from|key|association|of|one|many|to|inner|left|right|full|outer|join|on|where|group|by|having|union|all|distinct|excluding|corresponding|mixin|redirected|composition|parent|child|root|provider|contract|transactional_query|analytical_query|in|hierarchy)\\b"
        },
        {
          "name": "keyword.other.expression.cds",
          "match": "(?i)\\b(?:case|when|then|else|end|cast|and|or|not|between|like|is|null|initial|exists|in)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "support.function.builtin.cds",
          "match": "(?i)\\b(?:avg|cast|coalesce|concat|concat_with_space|count|currency_conversion|dats_add_days|dats_days_between|division|get_numeric_value|max|min|replace|round|substring|sum|unit_conversion|upper|lower|length|abs|ceil|floor|mod|power|session_context)\\b(?=\\s*\\()"
        },
        {
          "name": "entity.name.function.cds",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b(?=\\s*\\()"
        }
      ]
    },
    "qualified-names": {
      "patterns": [
        {
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(\\.)([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "variable.other.object.cds" },
            "2": { "name": "punctuation.accessor.dot.cds" },
            "3": { "name": "variable.other.member.cds" }
          }
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.cds",
          "match": "(?<![A-Za-z0-9_])(?:\\d+\\.\\d+|\\d+)(?![A-Za-z0-9_])"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.named-argument.cds",
          "match": "=>"
        },
        {
          "name": "keyword.operator.comparison.cds",
          "match": "<>|<=|>=|=|<|>"
        },
        {
          "name": "keyword.operator.arithmetic.cds",
          "match": "[-+*/]"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        { "name": "punctuation.separator.comma.cds", "match": "," },
        { "name": "punctuation.terminator.statement.cds", "match": ";" },
        { "name": "punctuation.section.braces.cds", "match": "[{}]" },
        { "name": "punctuation.section.brackets.cds", "match": "[\\[\\]]" },
        { "name": "punctuation.section.parens.cds", "match": "[()]" }
      ]
    }
  }
}
