        {
          "name": "keyword.other.abap",
          "match": "(?i:(?<![!\\-~>/])\\b(?:ACCEPTING|ADJACENT|ALL|AND|APPENDING|AS|ASCENDING|ASSIGNED|ASSIGNING|ASYNCHRONOUS|BADI|BASE|BETWEEN|BINARY|BLANKS|BLOCK|BOUND|BUFFER|BYPASSING|BY|BYTE|CALLING|CAST|CASTING|CHANGING|CHECKBOX|CLIENT|COMMENT|COMPARING|COMPONENTS|CONNECTION|CONSTANTS|CORRESPONDING|CRITICAL|CURRENT|CURSOR|DATABASE|DEFAULT|DEEP|DEFERRED|DELETING|DESCENDING|DESTINATION|DISPLAY|DISTINCT|DUPLICATES|DURATION|EMPTY|ENABLED|ENTRIES|ENUM|EVENT|EVENTS|EXCEPT|EXCEPTION|EXCEPTIONS|EXPORTING|EXTENSION|FIELDS|FILTER|FILTERS|FINAL|FIRST|FOR|FRAME|FRIENDS|FROM|GAPS|GROUP|HARMLESS|HAVING|ID|IGNORING|IMPLEMENTATION|IMPORTING|IN|INHERITING|INIT|INNER|INSTANCE|INTERFACES|INTERVALS|INTO|JOIN|KEY|LENGTH|LET|LINE|LINES|LONG|LOWER|MAPPING|MATCH|MATCHCODE|MEDIUM|MEMORY|MODIF|MOVE|NEXT|NO|NON|NOT|OBLIGATORY|OCCURRENCE|OCCURRENCES|OF|ON|OPTION|OPTIONAL|OR|ORDER|OTHERS|OUTER|PACKAGE|PLACES|PRIMARY|PRIVATE|PROGRAM|PROTECTED|PUBLIC|PUSHBUTTON|RADIOBUTTON|RAISING|RECEIVING|REDEFINITION|REDUCE|REFRESH|REGEX|RESUMABLE|RETURNING|RISK|ROWS|SCREEN|SECONDS|SECTION|SELECTION|SEPARATED|SHARED|SIGN|SHORT|SINGLE|SIZE|SPECIFIED|STABLE|STARTING|STATIC|STATICS|SUBMATCHES|SUPPLIED|TASK|TESTING|THEN|TITLE|TIME|STAMP|TO|TRANSPORTING|TRAILING|UNION|UNIQUE|UNTIL|UP|USING|VALUE|VALUES|VISIBLE|WHERE|WITH|WORK|ZONE)\\b(?![-~/]))"
        },
        {
          "name": "keyword.operator.word.abap",
          "match": "(?i:(?<![!\\-~>/])\\b(?:BIT-AND|BIT-OR|BIT-XOR|CN|CO|CP|CS|EQ|GE|GT|LE|LT|M|NE|NS|NOT|O|Z)\\b(?![-~/]))"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.single.abap",
          "match": "'(?:''|[^'\\r\\n])*'"
        },
        {
          "name": "string.quoted.other.backtick.abap",
          "match": "`(?:``|[^`\\r\\n])*`"
        },
        {
          "name": "string.template.abap",
          "begin": "\\|",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.abap"
            }
          },
          "end": "(?<!\\\\)\\|",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.abap"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.abap",
              "match": "\\\\[\\\\|{}]"
            },
            {
              "name": "meta.interpolation.abap",
              "begin": "(?<!\\\\)\\{",
              "beginCaptures": {
                "0": {
                  "name": "punctuation.section.interpolation.begin.abap"
                }
              },
              "end": "(?<!\\\\)\\}",
              "endCaptures": {
                "0": {
                  "name": "punctuation.section.interpolation.end.abap"
                }
              },
              "patterns": [
                {
                  "include": "#composite-keywords"
                },
                {
                  "include": "#keywords"
                },
                {
                  "include": "#numbers"
                },
                {
                  "include": "#constants"
                },
                {
                  "include": "#identifiers"
                },
                {
                  "include": "#operators"
                }
              ]
            }
          ]
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.asterisk.abap",
          "match": "^[ \\t]*\\*.*$"
        },
        {
          "name": "comment.line.double-quote.abap",
          "match": "\".*$"
        }
      ]
    },
    "pragmas": {
      "patterns": [
        {
          "name": "keyword.other.directive.pragma.abap",
          "match": "##[A-Z_][A-Z0-9_]*(?:\\[[^]\\r\\n]*\\])?"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.abap",
          "match": "(?i:(?<![A-Z0-9_])\\d+(?:\\.\\d+)?(?![A-Z0-9_]))"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "variable.language.system.abap",
          "match": "(?i:(?<![!\\-~>/])\\bSY-[A-Z0-9_]+\\b)"
        },
        {
          "name": "constant.other.text-symbol.abap",
          "match": "(?i:(?<![!\\-~>/])\\bTEXT-[A-Z0-9_]+\\b)"
        },
        {
          "name": "constant.language.abap",
          "match": "(?i:(?<![!\\-~>/])\\b(?:ABAP_FALSE|ABAP_TRUE|ABAP_UNDEFINED|SPACE)\\b(?![-~/]))"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.readwrite.field-symbol.abap",
          "match": "(?i:<[/A-Z_][A-Z0-9_/]*>)"
        },
        {
          "name": "variable.other.readwrite.abap",
          "match": "(?i:!?/?[A-Z_][A-Z0-9_/]*(?:[-~][A-Z0-9_/]+)*)"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "punctuation.accessor.abap",
          "match": "->|=>|~"
        },
        {
          "name": "keyword.operator.abap",
          "match": "<>|<=|>=|=|<|>|\\+|-|\\*|/"
        },
        {
          "name": "keyword.operator.host-variable.abap",
          "match": "@"
        },
        {
          "name": "punctuation.terminator.statement.abap",
          "match": "\\."
        },
        {
          "name": "punctuation.separator.abap",
          "match": "[:,]"
        }
      ]
    }
  }
}
